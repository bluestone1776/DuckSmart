# DuckSmart Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# OpenWeatherMap (free tier)
OWM_API_KEY=

# Regrid Parcel API
REGRID_TOKEN=

# OpenAI (GPT-4o Vision — AI Duck ID + Spread Analyzer)
OPENAI_API_KEY=

# eBird API v2 (free — https://ebird.org/api/keygen)
EBIRD_API_KEY=

# Google Maps (Android map tiles)
GOOGLE_MAPS_API_KEY=

# Firebase
FIREBASE_ANDROID_API_KEY=
FIREBASE_IOS_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_ANDROID_APP_ID=
FIREBASE_IOS_APP_ID=
FIREBASE_GOOGLE_WEB_CLIENT_ID=
